generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat        = "cjs"
  generatedFileExtension = "ts"
  importFileExtension = ""
}

datasource db {
  provider = "postgres"
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
